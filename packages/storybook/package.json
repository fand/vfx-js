{
  "name": "@vfx-js/storybook",
  "private": true,
  "version": "0.0.19",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "npm run build-storybook",
    "build-storybook": "storybook build -o docs-build",
    "clean": "rm -rf docs-build"
  },
  "dependencies": {
    "@vfx-js/core": "0.13.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-vfx": "0.18.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@storybook/addon-docs": "^9.0.6",
    "@storybook/html-vite": "^9.0.6",
    "@types/node": "^22.15.30",
    "storybook": "^9.0.6"
  },
  "overrides": {
    "storybook": "$storybook"
  }
}
