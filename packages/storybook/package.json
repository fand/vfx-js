{
  "name": "@vfx-js/storybook",
  "private": true,
  "version": "0.0.19",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "pnpm run build-storybook",
    "build-storybook": "storybook build -o docs-build",
    "clean": "rm -rf docs-build"
  },
  "dependencies": {
    "@vfx-js/core": "0.13.0",
    "@vfx-js/effects": "workspace:*",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@vfx-js/react": "0.18.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/html-vite": "10.3.5",
    "@tweakpane/core": "2.0.5",
    "@types/node": "24.12.2",
    "storybook": "10.3.5",
    "tweakpane": "4.0.5"
  },
  "overrides": {
    "storybook": "$storybook"
  }
}
