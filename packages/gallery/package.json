{
    "name": "@vfx-js/gallery",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview --host --port 3002 --strictPort",
