{
  "name": "docs",
  "private": true,
  "version": "0.0.19",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm-run-all -p build:typedoc build:storybook build:gallery build:tsc -s build:docs build:typedoc-dist build:storybook-dist",
    "build:tsc": "tsc",
    "build:typedoc": "rm -rf typedoc && cp -a ../vfx-js/docs-build typedoc",
    "build:storybook": "rm -rf storybook && cp -a ../storybook/docs-build storybook",
    "build:gallery": "rm -rf gallery && cp -a ../gallery/docs-build gallery",
    "build:docs": "vite build",
    "build:typedoc-dist": "rm -rf dist/docs && cp -a typedoc dist/docs",
    "build:storybook-dist": "rm -rf dist/storybook && cp -a storybook dist/storybook",
    "preview": "vite preview",
    "clean": "rimraf dist storybook typedoc gallery"
  },
  "dependencies": {
    "@vfx-js/core": "0.13.0",
    "@vfx-js/gallery": "0.0.19",
    "@vfx-js/storybook": "0.0.19",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.0.1",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
