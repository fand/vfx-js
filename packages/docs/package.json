{
  "name": "docs",
  "private": true,
  "version": "0.0.23",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm-run-all -p build:typedoc build:storybook build:examples build:tsc -s build:docs build:typedoc-dist build:storybook-dist build:examples-dist",
    "build:tsc": "tsc",
    "build:typedoc": "rm -rf typedoc && cp -a ../vfx-js/docs-build typedoc",
    "build:storybook": "rm -rf storybook && cp -a ../storybook/docs-build storybook",
    "build:examples": "rm -rf examples && cp -a ../examples/docs-build examples",
    "build:docs": "vite build",
    "build:typedoc-dist": "rm -rf dist/docs && cp -a typedoc dist/docs",
    "build:storybook-dist": "rm -rf dist/storybook && cp -a storybook dist/storybook",
    "build:examples-dist": "rm -rf dist/examples && cp -a examples dist/examples",
    "preview": "vite preview",
    "clean": "rimraf dist storybook typedoc examples"
  },
  "dependencies": {
    "@vfx-js/core": "workspace:*",
    "@vfx-js/effects": "workspace:*",
    "@vfx-js/examples": "workspace:*",
    "@vfx-js/storybook": "workspace:*",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/prismjs": "1.26.6",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
